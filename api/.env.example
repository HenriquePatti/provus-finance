# Porta em que a API vai rodar
PORT=3000

# Ambiente de execução (development, production, test)
NODE_ENV=development

# JWT - Chave secreta para assinar os tokens
# IMPORTANTE: Em produção, use uma string longa e aleatória
JWT_SECRET=sua-chave-secreta-super-segura-trocar-em-producao
JWT_EXPIRES_IN=24h

# Banco de dados
DB_PATH=./database/provus.db

# Bcrypt - custo do hash (10 é o padrão recomendado)
BCRYPT_ROUNDS=10