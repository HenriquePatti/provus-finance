{
  "name": "provus-finance-api",
  "version": "0.1.0",
  "description": "API REST para gestão financeira pessoal — Provus Finance",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "NODE_ENV=test mocha tests/api/**/*.test.js --timeout 10000",
    "test:watch": "NODE_ENV=test mocha tests/api/**/*.test.js --timeout 10000 --watch",
    "test:setup": "NODE_ENV=test node database/run-migrations.js",
    "db:migrate": "node database/run-migrations.js",
    "db:seed": "node database/run-seeds.js",
    "db:reset": "rm -f database/provus.db && npm run db:migrate && npm run db:seed"
  },
  "keywords": [
    "finance",
    "api",
    "express",
    "sqlite",
    "jwt"
  ],
  "author": "Henrique Patti",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "chai": "^5.1.1",
    "mocha": "^10.7.3",
    "supertest": "^7.0.0"
  }
}